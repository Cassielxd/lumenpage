{
  "name": "lumenpage-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "dev": "pnpm -C apps/playground dev",
    "dev:lumen": "pnpm -C apps/lumen dev",
    "docs:dev": "pnpm -C apps/docs dev",
    "docs:build": "pnpm -C apps/docs build",
    "docs:preview": "pnpm -C apps/docs preview",
    "docs:sync:lumen-menu": "node scripts/sync-lumen-menu-feature-checklist.mjs",
    "docs:check:lumen-menu": "node scripts/sync-lumen-menu-feature-checklist.mjs --check",
    "build": "pnpm -r build",
    "build:app": "pnpm -C apps/playground build",
    "build:lumen": "pnpm -C apps/lumen build",
    "test:lumen:e2e": "pnpm -C apps/lumen test:e2e",
    "test:engine": "pnpm -C packages/engine/view-runtime test && pnpm -C packages/engine/render-engine test && pnpm -C packages/engine/view-canvas test",
    "affected:list": "node scripts/affected-packages.mjs list",
    "typecheck:affected": "node scripts/affected-packages.mjs run typecheck",
    "build:affected": "node scripts/affected-packages.mjs run build",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "governance:budget:measure": "node scripts/measure-build-budgets.mjs",
    "governance:check:layers": "node scripts/check-package-governance.mjs",
    "governance:check:nodes": "node scripts/check-node-package-template.mjs",
    "governance:check:runtime-sync": "node scripts/check-view-runtime-sync.mjs",
    "governance:check:layout-redirects": "node scripts/check-layout-engine-redirects.mjs",
    "governance:check:plugins": "node scripts/check-plugin-aggregation-imports.mjs",
    "governance:check:node-baselines": "node scripts/check-node-test-baseline.mjs",
    "governance:check:budget": "node scripts/check-governance-budgets.mjs",
    "governance:check:no-legacy-wrappers": "node scripts/check-no-legacy-wrapper-packages.mjs",
    "governance:check:app-config": "node scripts/check-app-config-consistency.mjs",
    "governance:check:smoke-gate": "node scripts/check-playground-smoke-gate.mjs",
    "governance:check": "pnpm governance:check:layers && pnpm governance:check:nodes && pnpm governance:check:runtime-sync && pnpm governance:check:layout-redirects && pnpm governance:check:plugins && pnpm governance:check:node-baselines && pnpm governance:check:budget && pnpm governance:check:no-legacy-wrappers && pnpm governance:check:app-config && pnpm governance:check:smoke-gate && pnpm docs:check:lumen-menu",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "dev:app": "pnpm -C apps/playground dev",
    "dev:backend": "pnpm -C apps/backend-server dev",
    "start:backend": "pnpm -C apps/backend-server start",
    "build:backend": "pnpm -C apps/backend-server build",
    "dev:collab": "pnpm -C apps/backend-server dev",
    "start:collab": "pnpm -C apps/backend-server start",
    "build:collab": "pnpm -C apps/backend-server build",
    "test:core:characterization": "node ./packages/core/core/tests/run-characterization-tests.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "orderedmap": "2.1.1",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30"
  }
}
