{
  "name": "lumenpage-markdown",
  "version": "0.0.1",
  "description": "LumenPage Markdown integration",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts",
      "development": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "license": "MIT",
  "dependencies": {
    "@types/markdown-it": "^14.0.0",
    "lumenpage-core": "workspace:*",
    "lumenpage-extension-image": "workspace:*",
    "lumenpage-extension-link": "workspace:*",
    "lumenpage-extension-table": "workspace:*",
    "lumenpage-extension-underline": "workspace:*",
    "lumenpage-extension-video": "workspace:*",
    "lumenpage-link": "workspace:*",
    "markdown-it": "^14.0.0",
    "lumenpage-model": "workspace:*",
    "lumenpage-starter-kit": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false --noEmit"
  }
}
