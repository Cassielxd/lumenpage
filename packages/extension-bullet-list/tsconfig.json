{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "lumenpage-core": [
        "../core/src/index.ts"
      ],
      "lumenpage-extension-list-item": [
        "../extension-list-item/src/index.ts"
      ],
      "lumenpage-render-engine": [
        "../render-engine/src/index.ts"
      ]
    }
  },
  "include": [
    "src"
  ],
  "references": [
    {
      "path": "../core"
    },
    {
      "path": "../extension-list-item"
    },
    {
      "path": "../render-engine"
    }
  ]
}
