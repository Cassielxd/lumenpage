{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": []
  },
  "include": [
    "src/index.ts",
    "src/app.ts",
    "src/controller.ts",
    "src/styles.ts",
    "src/types.ts",
    "src/shims.d.ts",
    "src/utils/format-selection-object.ts",
    "src/utils/find-node.ts",
    "src/utils/subscribe-on-updates.ts",
    "src/state/idle-scheduler.ts",
    "src/state/json-diff-main.ts",
    "src/state/json-diff-worker.ts",
    "src/types/window.ts",
    "src/types/prosemirror.ts"
