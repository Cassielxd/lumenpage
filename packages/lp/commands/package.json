{
  "name": "lumenpage-commands",
  "version": "0.0.1",
  "description": "Editing commands for ProseMirror",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "license": "MIT",
  "maintainers": [
    {
      "name": "Marijn Haverbeke",
      "email": "marijn@haverbeke.berlin",
      "web": "http://marijnhaverbeke.nl"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/prosemirror/prosemirror-commands.git"
  },
  "dependencies": {
    "lumenpage-model": "workspace:*",
    "lumenpage-transform": "workspace:*",
    "lumenpage-state": "workspace:*",
    "lumenpage-view-types": "workspace:*"
  }
}

