{
  "name": "lumenpage-extension-changeset",
  "version": "0.0.1",
  "description": "Changeset utilities adapted for LumenPage",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "license": "MIT",
  "maintainers": [
    {
      "name": "Marijn Haverbeke",
      "email": "marijn@haverbeke.berlin",
      "web": "http://marijnhaverbeke.nl"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/prosemirror/prosemirror-changeset.git"
  },
  "dependencies": {
    "lumenpage-model": "workspace:*",
    "lumenpage-transform": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false --noEmit"
  }
}
