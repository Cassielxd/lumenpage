{
  "name": "lumenpage-view-canvas",
  "version": "0.0.2",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js",
      "development": "./src/core/index.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.js"
    },
    "./mapping": {
      "types": "./src/mapping/offsetMapping.ts",
      "default": "./dist/mapping/offsetMapping.js",
      "development": "./src/mapping/offsetMapping.ts",
      "import": "./dist/mapping/offsetMapping.js",
      "require": "./dist/mapping/offsetMapping.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false --noEmit"
  },
  "dependencies": {
    "lumenpage-link": "workspace:*",
    "lumenpage-layout-engine": "workspace:*",
    "lumenpage-render-engine": "workspace:*",
    "lumenpage-view-runtime": "workspace:*"
  },
  "peerDependencies": {
    "lumenpage-model": "workspace:*",
    "lumenpage-state": "workspace:*",
    "lumenpage-transform": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "lumenpage-model": "workspace:*",
    "lumenpage-state": "workspace:*",
    "lumenpage-transform": "workspace:*"
  }
}

