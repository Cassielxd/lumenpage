{
  "name": "lumenpage-gapcursor",
  "version": "0.0.1",
  "description": "LumenPage plugin for cursors at normally impossible-to-reach positions",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./style/gapcursor.css": "./style/gapcursor.css"
  },
  "files": [
    "dist",
    "style"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -p tsconfig.json --pretty false --noEmit"
  },
  "sideEffects": [
    "./style/gapcursor.css"
  ],
  "style": "style/gapcursor.css",
  "license": "MIT",
  "maintainers": [
    {
      "name": "Marijn Haverbeke",
      "email": "marijn@haverbeke.berlin",
      "web": "http://marijnhaverbeke.nl"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/prosemirror/prosemirror-gapcursor.git"
  },
  "dependencies": {
    "lumenpage-editor-plugins": "workspace:*"
  }
}

